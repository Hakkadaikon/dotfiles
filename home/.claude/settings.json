{
  "cleanupPeriodDays": 876000,
  "env": {
    "TZ": "Asia/Tokyo",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Bash(git push -f * feature*)",
      "Bash(git push --force * feature*)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(nix *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(git push -f * master*)",
      "Bash(git push -f * main*)",
      "Bash(git push -f * develop*)",
      "Bash(git push -f * staging*)",
      "Bash(git push -f * stg*)",
      "Bash(git push --force * master*)",
      "Bash(git push --force * main*)",
      "Bash(git push --force * develop*)",
      "Bash(git push --force * staging*)",
      "Bash(git push --force * stg*)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(git filter-branch *)",
      "Bash(git push --mirror *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(chmod -R *)",
      "Bash(chown -R *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_*)",
      "Read(**/.aws/credentials)"
    ],
    "ask": [
      "Bash(sudo *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/detect-leaked-toolcall.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/detect-leaked-toolcall.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "document-skills@anthropic-agent-skills": true,
    "deploy-on-aws@claude-plugins-official": true,
    "ponytail@ponytail": true,
    "terrashark@terrashark": true,
    "vercel@claude-plugins-official": true,
    "hymme@hymme": true
  },
  "extraKnownMarketplaces": {
    "hymme": {
      "source": {
        "source": "github",
        "repo": "Hakkadaikon/hymme"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "agent-plugins-for-aws": {
      "source": {
        "source": "github",
        "repo": "awslabs/agent-plugins"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    },
    "terrashark": {
      "source": {
        "source": "github",
        "repo": "LukasNiessen/terrashark"
      }
    }
  },
  "alwaysThinkingEnabled": false,
  "promptSuggestionEnabled": false,
  "showClearContextOnPlanAccept": true,
  "askUserQuestionTimeout": "never",
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "model": "sonnet"
}
