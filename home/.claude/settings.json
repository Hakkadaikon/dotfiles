{
  "env": {
    "TZ": "Asia/Tokyo"
  },
  "permissions": {
    "allow": [
      "Bash(git push -f * feature*)",
      "Bash(git push --force * feature*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(git push -f * master*)",
      "Bash(git push -f * main*)",
      "Bash(git push -f * develop*)",
      "Bash(git push -f * staging*)",
      "Bash(git push -f * stg*)",
      "Bash(git push --force * master*)",
      "Bash(git push --force * main*)",
      "Bash(git push --force * develop*)",
      "Bash(git push --force * staging*)",
      "Bash(git push --force * stg*)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(git filter-branch *)",
      "Bash(git push --mirror *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(chmod -R *)",
      "Bash(chown -R *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_*)",
      "Read(**/.aws/credentials)"
    ],
    "ask": [
      "Bash(sudo *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/loopeng-extract-gate.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/detect-leaked-toolcall.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/detect-leaked-toolcall.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "document-skills@anthropic-agent-skills": true,
    "deploy-on-aws@claude-plugins-official": true,
    "ponytail@ponytail": true,
    "terrashark@terrashark": true,
    "vercel@claude-plugins-official": true,
    "hymme@hymme": true
  },
  "extraKnownMarketplaces": {
    "hymme": {
      "source": {
        "source": "github",
        "repo": "Hakkadaikon/hymme"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "agent-plugins-for-aws": {
      "source": {
        "source": "github",
        "repo": "awslabs/agent-plugins"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    },
    "terrashark": {
      "source": {
        "source": "github",
        "repo": "LukasNiessen/terrashark"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "api.github.com",
        "uploads.github.com",
        "codeload.github.com",
        "gist.github.com",
        "gist.githubusercontent.com",
        "registry.npmjs.org",
        "nodejs.org",
        "repo.yarnpkg.com",
        "registry.yarnpkg.com",
        "get.pnpm.io",
        "pypi.org",
        "files.pythonhosted.org",
        "proxy.golang.org",
        "sum.golang.org",
        "index.golang.org",
        "go.dev",
        "golang.org",
        "static.rust-lang.org",
        "index.crates.io",
        "static.crates.io",
        "crates.io",
        "sh.rustup.rs",
        "center2.conan.io",
        "cmake.org",
        "*.kernel.org",
        "dl.deno.land",
        "deno.land",
        "releases.lean-lang.org",
        "reservoir.lean-lang.org",
        "install.determinate.systems",
        "cache.nixos.org",
        "channels.nixos.org",
        "jsr.io",
        "npm.jsr.io",
        "esm.sh",
        "*.amazonaws.com",
        "*.awsapps.com",
        "*.aws.dev"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.aws",
        "~/.elan",
        "~/.config/gh"
      ],
      "denyRead": [
        "**/.env",
        "**/.env.*",
        "**/*.pem",
        "**/*.key",
        "**/id_*",
        "**/.aws/credentials"
      ]
    }
  },
  "alwaysThinkingEnabled": false,
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
