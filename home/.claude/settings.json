{
  "model": "opus[1m]",
  "env": {
    "TZ": "Asia/Tokyo"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "document-skills@anthropic-agent-skills": true,
    "deploy-on-aws@claude-plugins-official": true,
    "ponytail@ponytail": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "agent-plugins-for-aws": {
      "source": {
        "source": "github",
        "repo": "awslabs/agent-plugins"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "denyRead": [
        "**/.env",
        "**/.env.*",
        "**/*.pem",
        "**/*.key",
        "**/id_*",
        "**/.aws/credentials"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(git push -f * feature*)",
      "Bash(git push --force * feature*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(git push -f * master*)",
      "Bash(git push -f * main*)",
      "Bash(git push -f * develop*)",
      "Bash(git push -f * staging*)",
      "Bash(git push -f * stg*)",
      "Bash(git push --force * master*)",
      "Bash(git push --force * main*)",
      "Bash(git push --force * develop*)",
      "Bash(git push --force * staging*)",
      "Bash(git push --force * stg*)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(git filter-branch *)",
      "Bash(git push --mirror *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(chmod -R *)",
      "Bash(chown -R *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_*)",
      "Read(**/.aws/credentials)"
    ],
    "ask": [
      "Bash(sudo *)"
    ]
  },
  "alwaysThinkingEnabled": false,
  "autoMemoryEnabled": false,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "theme": "dark-daltonized"
}
