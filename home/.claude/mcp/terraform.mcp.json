{
  "mcpServers": {
    "terraform": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "TFE_ADDRESS",
        "-e",
        "TFE_TOKEN",
        "hashicorp/terraform-mcp-server:1.0.0"
      ],
      "env": {
        "TFE_ADDRESS": "${TFE_ADDRESS:-https://app.terraform.io}",
        "TFE_TOKEN": "${TFE_TOKEN:-}"
      }
    }
  }
}
